# Shared NVIDIA driver version for GPU sandbox images.
# Referenced by:
#   - sandboxes/nvidia-gpu/build.sh (passes as --build-arg to Dockerfile)
#   - tasks/scripts/vm/build-nvidia-modules.sh (open-gpu-kernel-modules tag)
# Kernel modules and userspace MUST use the same driver release.
NVIDIA_DRIVER_VERSION=580.159.03
