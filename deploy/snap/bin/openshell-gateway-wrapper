set -eu

CANONICAL_CONFIG_FILE="${SNAP_COMMON}/gateway.toml"
CONFIG_FILE="${OPENSHELL_GATEWAY_CONFIG:-$CANONICAL_CONFIG_FILE}"
DB_URL="${OPENSHELL_DB_URL:-sqlite:${SNAP_COMMON}/gateway.db?mode=rwc}"

if [ ! -f "$CANONICAL_CONFIG_FILE" ]; then
    "${SNAP}/bin/init-gateway-config.sh" snap "$CANONICAL_CONFIG_FILE" "${SNAP}/bin/openshell-sandbox"
fi

export OPENSHELL_GATEWAY_CONFIG="$CONFIG_FILE"
exec "${SNAP}/bin/openshell-gateway" --config "$CONFIG_FILE" --db-url "$DB_URL" "$@"
